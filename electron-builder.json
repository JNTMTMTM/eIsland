{
  "appId": "com.eisland.app",
  "productName": "eIsland",
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "!out/renderer/.vite/**"
  ],
  "extraResources": [
    {
      "from": "resources/icon",
      "to": "icon",
      "filter": ["**/*"]
    },
    {
      "from": "resources/capture.html",
      "to": "capture.html"
    },
    {
      "from": "resources/capture.css",
      "to": "capture.css"
    },
    {
      "from": "resources/capture.js",
      "to": "capture.js"
    }
  ],
  "win": {
    "icon": "resources/icon/eisland_256x256.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "deleteAppDataOnUninstall": false
  }
}
